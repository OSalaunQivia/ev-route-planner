# SHA-256 hash of the access password. Generate locally with:
#   python3 -c "import hashlib, getpass; print(hashlib.sha256(getpass.getpass('Mot de passe : ').encode()).hexdigest())"
# Then paste the resulting hex string here.
ACCESS_PASSWORD_HASH = "paste_sha256_hash_here"
